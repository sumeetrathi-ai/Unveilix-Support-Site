# Unveilix Support — environment template.
# Copy to `.env` and fill in real values. Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit the real .env (it is gitignored).

# General
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5174
ENVIRONMENT=local
PROJECT_NAME="Unveilix Support"
STACK_NAME=unveilix-support

# CORS — origins allowed to call the API (the web app + local dev vite server)
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,http://localhost:5180,https://localhost"

# Security (CHANGE THESE)
SECRET_KEY=changethis

# First superuser (the Unveilix admin; seeded on startup). This email is also one of the
# seeded Unveilix admins, so keep FIRST_SUPERUSER_PASSWORD == the admin seed password.
FIRST_SUPERUSER=sumeet@unveilix.ai
FIRST_SUPERUSER_PASSWORD=changethis

# Seed account passwords. The pilot defaults live in backend/app/seed.py; override them here
# (local-only, never commit real values to a public repo) to keep secrets out of source.
# SEED_CLIENT_PASSWORD=
# SEED_ADMIN_PASSWORD=

# Email (optional; unused in v1)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=support@unveilix.ai
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres (runs inside Docker; host port is remapped to 5433 in compose.override.yml)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Observability (optional)
SENTRY_DSN=

# Docker image names
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
