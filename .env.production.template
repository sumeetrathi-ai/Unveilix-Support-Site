# ============================================================================
# Unveilix Support — PRODUCTION environment template
# ============================================================================
# SAFE TO COMMIT: placeholders only, NO real secrets. Copy each value into your
# hosting provider's environment settings (NOT into a committed file):
#   • Backend vars  -> Render service "Environment"
#   • Frontend var  -> Cloudflare Pages "Environment variables" (Build)
# The real .env (with actual values) stays local and is gitignored — never commit it.
#
# Replace every __PLACEHOLDER__ below. Lines that are commented out (#) are optional.
#
# ⚠️ STORAGE NOT YET IMPLEMENTED: uploaded screenshots/recordings currently write to a
#    LOCAL directory (UPLOADS_DIR). On Render that filesystem is EPHEMERAL (wiped on every
#    deploy/restart), so attachments will NOT persist until the Backblaze B2 / S3 swap is
#    built. The S3_* / STORAGE_BACKEND vars below are the agreed target names for that swap.
#
# NOTE: the backend reads SEPARATE Postgres vars (it does NOT accept a single DATABASE_URL).
#       Split Neon's connection string into the POSTGRES_* vars below.
# NOTE: DOMAIN, STACK_NAME, DOCKER_IMAGE_BACKEND/FRONTEND are docker-compose-only and are
#       NOT needed on Render or Cloudflare.
# ============================================================================


# ---------------------------------------------------------------------------
# DATABASE — Neon Postgres            (set on: Render, backend service)
# ---------------------------------------------------------------------------
# From Neon's connection string:  postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
POSTGRES_SERVER=__neon_host__              # the HOST part, e.g. ep-cool-name-123.us-east-2.aws.neon.tech
POSTGRES_PORT=5432                         # Neon uses 5432
POSTGRES_DB=__neon_database_name__         # e.g. neondb
POSTGRES_USER=__neon_user__                # e.g. neondb_owner
POSTGRES_PASSWORD=__neon_password__        # Neon Dashboard → Connection details (KEEP SECRET)
# Neon requires SSL. psycopg's default (sslmode=prefer) negotiates TLS and works with Neon;
# if you get an SSL error, that's a code tweak to track separately (do not change logic now).


# ---------------------------------------------------------------------------
# APP                                  (set on: Render, backend service)
# ---------------------------------------------------------------------------
ENVIRONMENT=production                      # local | staging | production
PROJECT_NAME="Unveilix Support"            # shown in the API / docs
# JWT signing key — KEEP SECRET. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=__generate_a_strong_random_value__

# Bootstrap admin (also one of the seeded Unveilix admins).
FIRST_SUPERUSER=sumeet@unveilix.ai          # the bootstrap admin email
FIRST_SUPERUSER_PASSWORD=__keep_equal_to_SEED_ADMIN_PASSWORD__   # MUST equal SEED_ADMIN_PASSWORD

# Optional (sensible defaults; usually leave unset):
# ACCESS_TOKEN_EXPIRE_MINUTES=11520         # default 8 days
# SENTRY_DSN=__sentry_dsn__                 # optional error tracking
# Email is unused in v1 — SMTP_* / EMAILS_FROM_* are not required.


# ---------------------------------------------------------------------------
# SEED — pilot account passwords       (set on: Render, backend service)
# ---------------------------------------------------------------------------
# Real values are NOT in source (seed.py has placeholders). Argon2-hashed at seed time.
# Shared per family for the pilot — ROTATE + force-change-on-first-login before external use.
SEED_CLIENT_PASSWORD=__carnera_client_pilot_password__   # all @getcarnera.com client users
SEED_ADMIN_PASSWORD=__unveilix_admin_pilot_password__    # all @unveilix.ai admins (== FIRST_SUPERUSER_PASSWORD)


# ---------------------------------------------------------------------------
# CORS / FRONTEND ORIGIN               (set on: Render, backend service)
# ---------------------------------------------------------------------------
# Must include the deployed frontend origin so the browser can call the API.
FRONTEND_HOST=https://__your-pages-project__.pages.dev    # your Cloudflare Pages URL (auto-added to CORS too)
BACKEND_CORS_ORIGINS=https://__your-pages-project__.pages.dev   # comma-separated; add custom domains here as well


# ---------------------------------------------------------------------------
# STORAGE — Backblaze B2 (S3-compatible)   (set on: Render, backend service)
# ⚠️ PENDING: not wired into the code yet (uploads still go to local disk). Target names:
# ---------------------------------------------------------------------------
STORAGE_BACKEND=s3                          # local (dev / current behavior) | s3 (production, once implemented)
S3_ENDPOINT_URL=https://s3.__region__.backblazeb2.com    # B2: Bucket details → Endpoint (region-specific)
S3_REGION=__region__                        # the region in the endpoint, e.g. us-west-004 (S3 SDKs usually require it)
S3_ACCESS_KEY_ID=__b2_application_key_id__  # B2: Application Keys → keyID
S3_SECRET_ACCESS_KEY=__b2_application_key__ # B2: Application Keys → applicationKey (KEEP SECRET)
S3_BUCKET=__b2_bucket_name__                # B2: the bucket name, e.g. unveilix-support-uploads
# UPLOADS_DIR=/app/uploads                   # only used when STORAGE_BACKEND=local


# ---------------------------------------------------------------------------
# FRONTEND BUILD                       (set on: Cloudflare Pages, build env var)
# ---------------------------------------------------------------------------
# Baked into the static build at build time, so it must point at the deployed backend.
VITE_API_URL=https://__your-render-service__.onrender.com   # Render backend URL, NO trailing slash
